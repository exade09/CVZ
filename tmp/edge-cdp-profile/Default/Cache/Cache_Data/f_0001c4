  transform: rotate(7deg);
  pointer-events: none;
}

.kvz-game-enemy:is(.shield-damaged, .shield-critical):not(.is-shield-broken)::after {
  position: absolute;
  top: 27%;
  right: 10%;
  z-index: 6;
  width: 32%;
  height: 40%;
  border-right: 3px solid rgba(220, 252, 255, 0.9);
  border-bottom: 3px solid rgba(94, 204, 226, 0.9);
  content: "";
  transform: skew(-17deg) rotate(-9deg);
  pointer-events: none;
}

.kvz-game-image-fallback {
  display: inline-grid;
  min-width: 64px;
  min-height: 64px;
  padding: 8px;
  place-items: center;
  border: 2px dashed rgba(37, 23, 15, 0.55);
  border-radius: 12px;
  color: var(--kvz-bark-deep);
  background:
    radial-gradient(circle at 50% 62%, var(--kvz-pink) 0 17%, transparent 18%),
    radial-gradient(circle at 34% 36%, var(--kvz-pink) 0 8%, transparent 9%),
    radial-gradient(circle at 66% 36%, var(--kvz-pink) 0 8%, transparent 9%),
    rgba(255, 253, 245, 0.72);
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.08em;
}

.kvz-game-defender > .kvz-game-image-fallback,
.kvz-game-enemy > .kvz-game-image-fallback {
  position: absolute;
  inset: 18% 9% 4%;
  z-index: 1;
}

.kvz-game-card > .kvz-game-image-fallback {
  width: 56px;
  min-width: 0;
  height: 76px;
  min-height: 0;
  grid-column: 1;
  grid-row: 1 / 4;
}

.kvz-game-defender.health-damaged .kvz-game-unit-sprite {
  filter: saturate(0.88) drop-shadow(0 0 4px var(--kvz-orange)) drop-shadow(0 6px 3px rgba(37, 23, 15, 0.25));
}

.kvz-game-defender.health-critical .kvz-game-unit-sprite {
  filter: saturate(0.7) contrast(0.95) drop-shadow(0 0 6px var(--kvz-danger)) drop-shadow(0 6px 3px rgba(37, 23, 15, 0.25));
}

.kvz-game-energy-orb {
  position: absolute;
  z-index: 35;
  display: grid;
  width: clamp(40px, 5.4%, 64px);
  aspect-ratio: 1;
  place-items: center;
  border: 3px solid var(--kvz-ink);
  border-radius: 50%;
  color: var(--kvz-ink);
  background:
    radial-gradient(circle at 32% 25%, rgba(255, 255, 255, 0.94) 0 10%, transparent 11%),
    radial-gradient(circle at 50% 60%, var(--kvz-orange) 0 23%, transparent 24%),
    var(--kvz-yellow);
  box-shadow: 0 0 18px rgba(255, 225, 93, 0.95), 0 5px 0 var(--kvz-bark);
  cursor: pointer;
  pointer-events: auto;
  touch-action: manipulation;
  animation: kvz-orb-float 1.7s ease-in-out infinite;
}

.kvz-game-energy-orb::before {
  width: 34%;
  height: 28%;
  border-radius: 50% 50% 45% 45%;
  content: "";
  background: var(--kvz-orange);
  box-shadow:
    -12px -10px 0 -4px var(--kvz-orange),
    -4px -15px 0 -4px var(--kvz-orange),
    5px -15px 0 -4px var(--kvz-orange),
    13px -10px 0 -4px var(--kvz-orange);
}

.kvz-game-energy-orb:hover,
.kvz-game-energy-orb:focus-visible {
  filter: brightness(1.08);
  transform: scale(1.08);
}

.kvz-game-energy-orb.is-collecting {
  animation: kvz-orb-collect 450ms var(--kvz-ease) forwards;
}

.kvz-game-sweeper {
  position: absolute;
  left: 0.3%;
  z-index: 20;
  width: 7.5%;
  height: 16%;
  border: 3px solid var(--kvz-ink);
  border-radius: 45% 55% 30% 30%;
  background:
    radial-gradient(circle at 31% 39%, var(--kvz-ink) 0 3px, transparent 4px),
    radial-gradient(circle at 63% 39%, var(--kvz-ink) 0 3px, transparent 4px),
    linear-gradient(145deg, var(--kvz-pink), #f5568d);
  box-shadow: 0 5px 0 var(--kvz-bark), inset -5px -6px 0 rgba(112, 67, 30, 0.18);
  transform: translateY(-50%);
  pointer-events: none;
}

.kvz-game-sweeper::before,
.kvz-game-sweeper::after {
  position: absolute;
  top: -18%;
  width: 38%;
  height: 42%;
  border: 3px solid var(--kvz-ink);
  border-radius: 10px 70% 10px 60%;
  content: "";
  background: var(--kvz-pink);
}

.kvz-game-sweeper::before {
  left: 4%;
  transform: rotate(-25deg);
}

.kvz-game-sweeper::after {
  right: 4%;
  transform: rotate(25deg) scaleX(-1);
}

.kvz-game-sweeper.is-active {
  animation: kvz-sweeper-run 1.2s linear forwards;
}

.kvz-game-sweeper.is-used {
  opacity: 0.25;
  filter: grayscale(1);
}

.kvz-game-status-slow .kvz-game-unit-sprite,
.kvz-game-enemy.status-slow .kvz-game-unit-sprite {
  filter: hue-rotate(145deg) saturate(0.8) drop-shadow(0 0 7px #bdfaff) drop-shadow(0 6px 3px rgba(37, 23, 15, 0.22));
}

.kvz-game-status-root .kvz-game-unit-sprite,
.kvz-game-enemy.status-root .kvz-game-unit-sprite {
  filter: sepia(0.32) saturate(1.25) drop-shadow(0 0 7px #ffe15d) drop-shadow(0 6px 3px rgba(37, 23, 15, 0.22));
  animation-play-state: paused;
}

.kvz-game-status-weakened .kvz-game-unit-sprite,
.kvz-game-enemy.status-weakened .kvz-game-unit-sprite {
  filter: saturate(0.55) contrast(0.9) drop-shadow(0 0 7px var(--kvz-pink)) drop-shadow(0 6px 3px rgba(37, 23, 15, 0.22));
}

.kvz-game-damage-flash .kvz-game-unit-sprite,
.kvz-game-defender.is-hit .kvz-game-unit-sprite,
.kvz-game-enemy.is-hit .kvz-game-unit-sprite {
  animation: kvz-damage-flash 220ms ease both;
}

.kvz-game-defeated,
.kvz-game-defender.is-defeated,
.kvz-game-enemy.is-defeated {
  pointer-events: none;
  animation: kvz-defeated 460ms var(--kvz-ease) forwards;
}

.kvz-game-toast-stack {
  position: absolute;
  top: 78px;
  right: 14px;
  z-index: 90;
  display: grid;
  width: min(330px, calc(100% - 28px));
  gap: 8px;
  pointer-events: none;
}

.kvz-game-toast {
  position: relative;
  padding: 10px 14px;
  border: 3px solid var(--kvz-ink);
  border-radius: 10px;
  background: linear-gradient(180deg, #fffbe2, #f2d486);
  box-shadow: 0 5px 0 var(--kvz-bark), 0 11px 20px var(--kvz-shadow);
  font-weight: 900;
  line-height: 1.15;
  animation: kvz-toast-in 250ms var(--kvz-ease) both;
}

.kvz-game-overlay.is-playing .kvz-game-toast-stack {
  top: max(8px, env(safe-area-inset-top));
  right: auto;
  left: 50%;
  width: clamp(180px, 34vw, 300px);
  gap: 4px;
  transform: translateX(-50%);
}

.kvz-game-overlay.is-playing .kvz-game-toast {
  padding: 6px 10px;
  border-width: 2px;
  font-size: 0.78rem;
  box-shadow: 0 3px 0 var(--kvz-bark), 0 7px 14px var(--kvz-shadow);
}

.kvz-game-toast.success {
  background: linear-gradient(180deg, #edffd8, #9be36b);
}

.kvz-game-toast.warning {
  background: linear-gradient(180deg, #fff4ad, #ffb247);
}

.kvz-game-toast.error {
  color: var(--kvz-paper);
  background: linear-gradient(180deg, #ff8d7a, var(--kvz-danger));
}

.kvz-game-final-warning {
  position: absolute;
  top: 50%;
  left: 50%;
  z-index: 80;
  width: min(720px, calc(100% - 36px));
  padding: clamp(14px, 3vw, 24px);
  border: 5px solid var(--kvz-ink);
  border-radius: 14px;
  color: var(--kvz-paper);
  background:
    repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.12) 0 12px, transparent 12px 24px),
    linear-gradient(180deg, #ff8a57, var(--kvz-danger));
  box-shadow: 0 8px 0 var(--kvz-bark-deep), 0 20px 40px rgba(37, 23, 15, 0.44);
  font-family: "Luckiest Guy", "Baloo 2", sans-serif;
  font-size: clamp(1.75rem, 5vw, 4rem);
  line-height: 1;
  text-align: center;
  text-shadow: 0 4px 0 var(--kvz-bark-deep);
  transform: translate(-50%, -50%);
  animation: kvz-warning-pop 1.8s var(--kvz-ease) both;
  pointer-events: none;
}

.kvz-game-overlay.is-paused .kvz-game-final-warning {
  animation-play-state: paused;
}

.kvz-game-modal-backdrop {
  position: absolute;
  inset: 0;
  z-index: 100;
  display: grid;
  padding: 18px;
  place-items: center;
  overflow: auto;
  background: rgba(37, 23, 15, 0.68);
  backdrop-filter: blur(4px);
}

.kvz-game-modal-backdrop[hidden] {
  display: none !important;
}

.kvz-game-frame > .kvz-game-paused {
  position: absolute;
  inset: 0;
  z-index: 100;
  display: grid;
  padding: 18px;
  place-items: center;
  overflow: auto;
  background: rgba(37, 23, 15, 0.68);
  backdrop-filter: blur(4px);
}

.kvz-game-frame > .kvz-game-paused[hidden] {
  display: none !important;
}

.kvz-game-paused > .kvz-game-panel {
  display: grid;
  width: min(560px, 100%);
  gap: 16px;
  justify-items: center;
  text-align: center;
}

.kvz-game-modal {
  position: relative;
  display: grid;
  width: min(590px, 100%);
  max-height: 100%;
  gap: 16px;
  padding: clamp(22px, 4vw, 40px);
  overflow: auto;
  border: 5px solid var(--kvz-ink);
  border-radius: 15px;
  background:
    radial-gradient(circle at 10% 12%, rgba(255, 130, 173, 0.26) 0 24px, transparent 25px),
    radial-gradient(circle at 90% 88%, rgba(255, 225, 93, 0.4) 0 34px, transparent 35px),
    linear-gradient(180deg, #fff9da, #efd28b);
  box-shadow: 0 9px 0 var(--kvz-bark), 0 26px 52px rgba(20, 12, 7, 0.52);
  text-align: center;
  animation: kvz-modal-in 220ms var(--kvz-ease) both;
}

.kvz-game-modal h2,
.kvz-game-modal p {
  position: relative;
  z-index: 1;
  margin: 0;
}

.kvz-game-modal h2 {
  color: var(--kvz-grass-deep);
  font-family: "Luckiest Guy", "Baloo 2", sans-serif;
  font-size: clamp(2rem, 6vw, 3.8rem);
  line-height: 0.95;
  -webkit-text-stroke: 2px var(--kvz-ink);
  paint-order: stroke fill;
  text-shadow: 0 4px 0 var(--kvz-bark);
}

.kvz-game-paused .kvz-game-modal,
.kvz-game-modal.paused {
  background:
    radial-gradient(circle at 50% 0, rgba(255, 225, 93, 0.5), transparent 12rem),
    linear-gradient(180deg, #fff9da, #efd28b);
}

.kvz-game-victory-confetti {
  position: absolute;
  inset: 0;
  z-index: 110;
  overflow: hidden;
  pointer-events: none;
}

.kvz-game-victory-confetti > i {
  position: absolute;
  top: -12%;
  left: var(--x, 50%);
  width: clamp(8px, 1vw, 14px);
  height: clamp(13px, 1.6vw, 22px);
  border: 2px solid var(--kvz-ink);
  border-radius: 4px;
  background: var(--color, var(--kvz-pink));
  animation: kvz-confetti-fall var(--duration, 2.8s) linear var(--delay, 0s) infinite;
}

.kvz-game-orientation-hint {
  position: absolute;
  inset: 0;
  z-index: 150;
  display: none;
  padding: 28px;
  place-items: center;
  background:
    radial-gradient(circle at 50% 35%, rgba(255, 225, 93, 0.58), transparent 15rem),
    linear-gradient(155deg, #9be36b, #4fad3d);
  text-align: center;
}

.kvz-game-orientation-hint .kvz-game-panel {
  display: grid;
  max-width: 420px;
  gap: 12px;
  justify-items: center;
}

.kvz-game-orientation-hint::before {
  width: 64px;
  height: 102px;
  border: 5px solid var(--kvz-ink);
  border-radius: 13px;
  content: "";
  background: linear-gradient(145deg, var(--kvz-sky), var(--kvz-pink));
  box-shadow: 0 7px 0 var(--kvz-bark);
  animation: kvz-turn-device 2.4s ease-in-out infinite;
}

.kvz-game-overlay :is(button, [href], input, select, textarea, [tabindex]):focus-visible {
  outline: 4px solid #fff;
  outline-offset: 2px;
  box-shadow: 0 0 0 7px var(--kvz-pink-deep), 0 5px 0 var(--kvz-bark);
}

.kvz-game-gameplay.is-paused .kvz-game-entity-layer *,
.kvz-game-overlay.is-paused .kvz-game-gameplay .kvz-game-entity-layer * {
  animation-play-state: paused !important;
}

.kvz-game-overlay.reduce-motion,
.kvz-game-overlay.reduce-motion *,
.kvz-game-overlay.reduce-motion *::before,
.kvz-game-overlay.reduce-motion *::after {
  scroll-behavior: auto !important;
  animation-duration: 0.001ms !important;
  animation-iteration-count: 1 !important;
  transition-duration: 0.001ms !important;
}

.kvz-game-overlay.screen-shake-enabled .kvz-game-frame.is-shaking {
  animation: kvz-screen-shake 320ms ease both;
}

.kvz-game-overlay .is-paused .kvz-game-modal,
.kvz-game-overlay.is-paused .kvz-game-modal {
  opacity: 1;
  animation: none;
  transform: none;
}

@keyframes kvz-menu-float {
