  70% { transform: translateY(-2%) rotate(-0.8deg); }
}

@keyframes kvz-frost-idle {
  0%, 100% { transform: translateY(0) rotate(-0.4deg); filter: drop-shadow(0 6px 3px rgba(37, 23, 15, 0.25)); }
  50% { transform: translateY(-3.5%) rotate(0.4deg) scale(1.01); filter: drop-shadow(0 0 6px rgba(153, 230, 237, 0.62)); }
}

@keyframes kvz-pop-idle {
