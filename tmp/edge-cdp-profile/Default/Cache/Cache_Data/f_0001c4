  70% { transform: translate(1.5%, -1%) rotate(-1.5deg) scale(0.99, 1.02); }
}

@keyframes kvz-heavy-idle {
  0%, 100% { transform: translateY(0) rotate(-0.4deg) scale(1.02, 0.98); }
  50% { transform: translateY(-2%) rotate(0.4deg) scale(0.99, 1.01); }
}

@keyframes kvz-guide-idle {
  0%, 100% { transform: translateY(0) rotate(-1deg); filter: drop-shadow(0 6px 3px rgba(37, 23, 15, 0.25)); }
  50% { transform: translateY(-4%) rotate(1deg) scale(1.015); filter: brightness(1.06) drop-shadow(0 0 7px rgba(168, 236, 54, 0.58)); }
}

@keyframes kvz-armored-step {
  0%, 100% { transform: translateY(0) rotate(-1deg) scale(1.01, 0.99); }
  50% { transform: translateY(-3.5%) rotate(1.2deg) scale(0.99, 1.015); }
}

@keyframes kvz-bucket-step {
  0%, 100% { transform: translateY(0) rotate(-1.4deg) scale(1.025, 0.975); }
  42% { transform: translateY(-2%) rotate(1.1deg) scale(0.99, 1.01); }
  55% { transform: translateY(0.5%) rotate(0); }
}

@keyframes kvz-shield-step {
  0%, 100% { transform: translateX(0) translateY(0) rotate(-0.5deg); }
  50% { transform: translateX(-1.5%) translateY(-2.5%) rotate(0.8deg) scale(1.01, 0.99); }
}

@keyframes kvz-brute-charge {
  0%, 100% { transform: translateX(1%) translateY(0) rotate(-2deg) scale(1.02, 0.98); }
  50% { transform: translateX(-2%) translateY(-5%) rotate(2deg) scale(0.99, 1.015); }
}

@keyframes kvz-producer-pulse {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 6px 3px rgba(37, 23, 15, 0.25)); }
  50% { transform: translateY(-7%) scale(1.12, 0.92); filter: brightness(1.18) drop-shadow(0 0 12px var(--kvz-yellow)); }
}

@keyframes kvz-twin-volley {
  0%, 100% { transform: translateX(0) scale(1); }
  26%, 68% { transform: translateX(-7%) scale(0.96, 1.04); }
  44%, 86% { transform: translateX(8%) scale(1.055, 0.96); }
}

@keyframes kvz-frost-cast {
  0%, 100% { transform: rotate(0) scale(1); }
  45% { transform: translateX(-5%) rotate(-3deg) scale(0.96, 1.04); filter: drop-shadow(0 0 11px var(--kvz-sky)); }
  72% { transform: translateX(7%) rotate(2deg) scale(1.04, 0.97); }
}

@keyframes kvz-heavy-recoil {
  0%, 100% { transform: translateX(0) scale(1); }
  38% { transform: translateX(-10%) rotate(-2deg) scale(0.92, 1.07); }
  72% { transform: translateX(10%) rotate(1deg) scale(1.08, 0.93); }
}

@keyframes kvz-guide-cast {
  0%, 100% { transform: translateY(0) rotate(0) scale(1); }
  45% { transform: translateY(-9%) rotate(-3deg) scale(1.08, 0.94); filter: brightness(1.12) drop-shadow(0 0 12px var(--kvz-lime)); }
  72% { transform: translateY(-2%) rotate(2deg) scale(0.98, 1.03); }
}

@keyframes kvz-pop-finale {
  0% { opacity: 1; transform: scale(1); }
  45% { opacity: 1; transform: translateY(-8%) rotate(4deg) scale(1.22, 0.82); filter: brightness(1.35) drop-shadow(0 0 15px var(--kvz-pink)); }
  100% { opacity: 0; transform: scale(1.7); }
}

@keyframes kvz-bucket-bash {
  0%, 100% { transform: translateX(0) rotate(0); }
  48% { transform: translateX(-7%) translateY(3%) rotate(-3deg) scale(1.05, 0.95); }
  70% { transform: translateX(-2%) rotate(1deg); }
}

@keyframes kvz-shield-bash {
  0%, 100% { transform: translateX(0) rotate(0); }
  40% { transform: translateX(-12%) rotate(-1deg) scale(1.07, 0.96); }
  67% { transform: translateX(-3%) rotate(0.5deg); }
}

@keyframes kvz-brute-bash {
  0%, 100% { transform: translateX(0) rotate(0); }
  38% { transform: translateX(-14%) rotate(-4deg) scale(1.09, 0.94); }
  62% { transform: translateX(-4%) rotate(2deg) scale(0.98, 1.02); }
}

@keyframes kvz-screen-shake {
  0%,
  100% { transform: translate3d(0, 0, 0); }
  24% { transform: translate3d(-5px, 2px, 0) rotate(-0.2deg); }
  48% { transform: translate3d(6px, -2px, 0) rotate(0.2deg); }
