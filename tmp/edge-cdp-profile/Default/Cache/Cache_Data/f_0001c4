@keyframes kvz-effect-pop {
  0% {
    opacity: 0;
    scale: 0.2;
  }
  35% {
    opacity: 1;
    scale: 1.35;
  }
  100% {
    opacity: 0;
    scale: 2.1;
  }
}

@keyframes kvz-dog-walk {
  0%,
  100% {
    transform: translateY(0) rotate(-1.5deg) scale(1, 1);
  }
  50% {
    transform: translateY(-5%) rotate(1.5deg) scale(1.02, 0.97);
  }
}

@keyframes kvz-cat-attack {
  0% {
    transform: translateX(0) scale(1);
  }
  38% {
    transform: translateX(-7%) scale(0.96, 1.05);
  }
  70% {
    transform: translateX(8%) scale(1.06, 0.96);
  }
  100% {
    transform: translateX(0) scale(1);
  }
}

@keyframes kvz-cat-place {
  0% {
    opacity: 0;
    transform: translateY(-35%) rotate(-6deg) scale(0.35);
  }
  62% {
    opacity: 1;
    transform: translateY(4%) rotate(2deg) scale(1.12, 0.9);
  }
  100% {
    opacity: 1;
    transform: translateY(0) rotate(0) scale(1);
  }
}

@keyframes kvz-dog-attack {
  0%,
  100% {
    transform: translateX(0) rotate(0);
  }
  44% {
    transform: translateX(-9%) rotate(-2deg) scale(1.04, 0.97);
  }
  66% {
    transform: translateX(-3%) rotate(1deg);
  }
}

@keyframes kvz-orb-float {
  0%,
  100% {
    translate: 0 0;
    rotate: -2deg;
  }
  50% {
    translate: 0 -8px;
    rotate: 2deg;
  }
}

@keyframes kvz-orb-collect {
  0% {
    opacity: 1;
    scale: 1;
    translate: 0 0;
  }
  65% {
    opacity: 1;
    scale: 1.25;
    translate: calc(var(--collect-x, 0px) * 0.35) calc(var(--collect-y, 0px) * 0.35);
  }
  100% {
    opacity: 0;
    scale: 0.2;
    translate: var(--collect-x, 0px) var(--collect-y, 0px);
  }
}

@keyframes kvz-damage-flash {
  0%,
  100% {
    filter: drop-shadow(0 6px 3px rgba(37, 23, 15, 0.25));
    transform: translateX(0);
  }
  30% {
    filter: brightness(2) saturate(0) drop-shadow(0 0 8px #fff);
    transform: translateX(-5%);
  }
  60% {
    filter: brightness(1.5) sepia(1) saturate(5) hue-rotate(320deg);
    transform: translateX(4%);
  }
}

@keyframes kvz-defeated {
  0% {
    opacity: 1;
    transform: rotate(0) scale(1);
  }
  55% {
    opacity: 1;
    transform: translateY(-12%) rotate(-8deg) scale(1.06, 0.88);
  }
  100% {
    opacity: 0;
    transform: translateY(38%) rotate(8deg) scale(0.16);
  }
}

@keyframes kvz-sweeper-run {
  0% {
    left: 0.3%;
    transform: translateY(-50%) rotate(0);
  }
  100% {
    left: 104%;
    transform: translateY(-50%) rotate(5deg);
  }
}

@keyframes kvz-invalid-shake {
  0%,
  100% {
    transform: translateX(0);
  }
  30% {
    transform: translateX(-4px);
  }
  70% {
    transform: translateX(4px);
  }
}

@keyframes kvz-toast-in {
  from {
    opacity: 0;
    transform: translateX(28px) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
}

@keyframes kvz-warning-pop {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.35) rotate(-4deg);
  }
  18% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.08) rotate(2deg);
  }
  28%,
  76% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) rotate(0);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.92);
  }
}

@keyframes kvz-modal-in {
  from {
    opacity: 0;
    transform: translateY(18px) scale(0.93);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes kvz-confetti-fall {
  0% {
    translate: 0 -10%;
    rotate: 0deg;
  }
  100% {
    translate: var(--drift, 20px) 115vh;
    rotate: 720deg;
  }
}

@keyframes kvz-turn-device {
  0%,
  20%,
  100% {
    transform: rotate(0);
  }
  55%,
  80% {
    transform: rotate(90deg);
  }
}

