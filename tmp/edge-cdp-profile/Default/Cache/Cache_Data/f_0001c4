:root {
  --kvz-ink: #25170f;
  --kvz-bark: #70431e;
  --kvz-bark-deep: #442817;
  --kvz-cream: #fff4c7;
  --kvz-paper: #fffdf5;
  --kvz-grass: #55c936;
  --kvz-grass-deep: #238b2b;
  --kvz-lime: #a8ec36;
  --kvz-mint: #dffbd1;
  --kvz-pink: #ff82ad;
  --kvz-pink-deep: #df4e83;
  --kvz-yellow: #ffe15d;
  --kvz-orange: #ff922f;
  --kvz-sky: #99e6ed;
  --kvz-blue: #5ecce2;
  --kvz-danger: #ef5b4f;
  --kvz-shadow: rgba(37, 23, 15, 0.28);
  --kvz-outline: 4px solid var(--kvz-ink);
  --kvz-radius: 12px;
  --kvz-ease: cubic-bezier(0.2, 0.8, 0.2, 1);
}

body.kvz-game-open {
  overflow: hidden;
  overscroll-behavior: none;
}

.kvz-game-overlay,
.kvz-game-overlay *,
.kvz-game-overlay *::before,
.kvz-game-overlay *::after {
  box-sizing: border-box;
}

.kvz-game-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: grid;
  min-width: 320px;
  padding:
    max(clamp(6px, 1.2vw, 18px), env(safe-area-inset-top))
    max(clamp(6px, 1.2vw, 18px), env(safe-area-inset-right))
    max(clamp(6px, 1.2vw, 18px), env(safe-area-inset-bottom))
    max(clamp(6px, 1.2vw, 18px), env(safe-area-inset-left));
  place-items: center;
  color: var(--kvz-ink);
  font-family: "Baloo 2", "Trebuchet MS", Arial, sans-serif;
  background:
    linear-gradient(rgba(28, 79, 30, 0.5), rgba(37, 23, 15, 0.64)),
    url("../kvz-fon.png") center / cover no-repeat,
    #76c959;
  opacity: 1;
  overscroll-behavior: contain;
  transition: opacity 220ms ease, visibility 220ms ease;
}

.kvz-game-overlay[hidden] {
  display: none !important;
}

.kvz-game-overlay.is-closing {
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
}

.kvz-game-overlay button,
.kvz-game-overlay input {
  font: inherit;
}

.kvz-game-overlay button,
.kvz-game-overlay [role="button"] {
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}

.kvz-game-overlay img {
  display: block;
  max-width: 100%;
}

.kvz-game-frame {
  position: relative;
  isolation: isolate;
  display: flex;
  width: min(1480px, 100%);
  height: min(920px, 100%);
  min-height: 420px;
  flex-direction: column;
  overflow: hidden;
  border: 5px solid var(--kvz-ink);
  border-radius: 18px;
  background: var(--kvz-cream);
  box-shadow:
    0 9px 0 var(--kvz-bark-deep),
    0 24px 70px rgba(25, 15, 9, 0.5),
    inset 0 0 0 4px rgba(255, 255, 255, 0.36);
}

.kvz-game-frame::after {
  position: absolute;
  inset: 7px;
  z-index: 50;
  border: 2px dashed rgba(112, 67, 30, 0.2);
  border-radius: 10px;
  content: "";
  pointer-events: none;
}

.kvz-game-overlay:fullscreen,
.kvz-game-overlay:-webkit-full-screen {
  padding: 0;
  background-color: #5eaa48;
}

.kvz-game-overlay:fullscreen .kvz-game-frame,
.kvz-game-overlay:-webkit-full-screen .kvz-game-frame,
.kvz-game-frame:fullscreen,
.kvz-game-frame:-webkit-full-screen {
  width: 100%;
  height: 100dvh;
  max-width: none;
  border-radius: 0;
}

.kvz-game-topbar {
  position: relative;
  z-index: 60;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 12px;
  align-items: center;
  min-height: 62px;
  padding: 8px 12px 10px;
  border-bottom: 4px solid var(--kvz-ink);
  background:
    radial-gradient(circle at 8% 50%, rgba(255, 130, 173, 0.38) 0 9px, transparent 10px),
    radial-gradient(circle at 90% 35%, rgba(255, 225, 93, 0.52) 0 12px, transparent 13px),
    linear-gradient(180deg, #fff9df, #efce8a);
  box-shadow: 0 5px 0 rgba(112, 67, 30, 0.52);
}

.kvz-game-topbar > :last-child {
  justify-self: end;
}

.kvz-game-brand-mark {
  display: inline-flex;
  min-width: 0;
  align-items: center;
  gap: 9px;
  font-family: "Luckiest Guy", "Baloo 2", sans-serif;
  font-size: clamp(1rem, 2vw, 1.42rem);
  color: var(--kvz-grass-deep);
  line-height: 1;
  letter-spacing: 0.02em;
  text-shadow: 2px 2px 0 var(--kvz-paper);
}

.kvz-game-brand-mark::before {
  width: 38px;
  height: 38px;
  flex: 0 0 auto;
  border: 3px solid var(--kvz-ink);
  border-radius: 50% 50% 46% 46%;
  content: "";
  background:
    radial-gradient(circle at 35% 48%, var(--kvz-ink) 0 2px, transparent 3px),
    radial-gradient(circle at 65% 48%, var(--kvz-ink) 0 2px, transparent 3px),
    radial-gradient(ellipse at 50% 66%, var(--kvz-pink) 0 4px, transparent 5px),
    linear-gradient(145deg, #efff9c, var(--kvz-lime));
  box-shadow: inset -4px -5px 0 rgba(112, 67, 30, 0.16), 0 3px 0 var(--kvz-bark);
}

.kvz-game-icon-button {
  position: relative;
  display: inline-grid;
  width: 44px;
  min-width: 44px;
  height: 44px;
  padding: 0;
  place-items: center;
  border: 3px solid var(--kvz-ink);
  border-radius: 10px;
  color: var(--kvz-ink);
  background: linear-gradient(180deg, var(--kvz-paper), #f3dc9f);
  box-shadow: 0 4px 0 var(--kvz-bark), inset 0 -3px 0 rgba(112, 67, 30, 0.1);
  cursor: pointer;
  transition: transform 150ms var(--kvz-ease), box-shadow 150ms var(--kvz-ease), filter 150ms ease;
}

.kvz-game-icon-button svg {
  width: 23px;
  height: 23px;
  fill: currentColor;
}

.kvz-game-icon-button:hover {
  filter: brightness(1.06) saturate(1.08);
  transform: translateY(-2px);
  box-shadow: 0 6px 0 var(--kvz-bark), 0 9px 16px var(--kvz-shadow);
}

.kvz-game-icon-button:active {
  transform: translateY(2px);
  box-shadow: 0 1px 0 var(--kvz-bark);
}

.kvz-game-screen {
  position: relative;
  z-index: 1;
  min-height: 0;
  flex: 1;
  overflow: auto;
  scrollbar-color: var(--kvz-pink) rgba(255, 244, 199, 0.8);
  scrollbar-width: thin;
}

.kvz-game-overlay.is-playing .kvz-game-screen {
  overflow: hidden;
}

.kvz-game-screen[hidden] {
  display: none !important;
}

.kvz-game-screen::-webkit-scrollbar,
.kvz-game-card-tray::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

.kvz-game-screen::-webkit-scrollbar-track,
.kvz-game-card-tray::-webkit-scrollbar-track {
  background: rgba(255, 244, 199, 0.82);
}

.kvz-game-screen::-webkit-scrollbar-thumb,
.kvz-game-card-tray::-webkit-scrollbar-thumb {
  border: 2px solid var(--kvz-ink);
  border-radius: 999px;
  background: var(--kvz-pink);
}

.kvz-game-menu-screen {
  display: grid;
  grid-template-columns: minmax(300px, 0.9fr) minmax(360px, 1.1fr);
  gap: clamp(18px, 4vw, 52px);
  align-items: center;
  min-height: 100%;
  padding: clamp(20px, 4vw, 56px);
  background:
    radial-gradient(circle at 8% 16%, rgba(255, 225, 93, 0.7) 0 6px, transparent 7px),
    radial-gradient(circle at 92% 72%, rgba(255, 130, 173, 0.62) 0 7px, transparent 8px),
    linear-gradient(rgba(255, 253, 245, 0.14), rgba(126, 211, 79, 0.18)),
    url("../kvz-fon.png") center / cover no-repeat,
    var(--kvz-grass);
}

.kvz-game-menu-hero {
  position: relative;
  z-index: 2;
  display: grid;
  gap: 14px;
  align-content: center;
}

.kvz-game-menu-art {
  position: relative;
  min-width: 0;
  max-width: 620px;
  justify-self: center;
  border: 5px solid var(--kvz-ink);
  border-radius: 20px;
  background:
    radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.7) 0 5%, transparent 5.4%),
    linear-gradient(150deg, #dffbd1, #7cdb55 56%, #4eae3e);
  box-shadow: 0 10px 0 var(--kvz-bark), 0 25px 44px var(--kvz-shadow);
  transform: rotate(1deg);
  animation: kvz-menu-float 4.5s ease-in-out infinite;
}

.kvz-game-menu-art::before,
.kvz-game-menu-art::after {
  position: absolute;
  z-index: 2;
  width: 38px;
  height: 38px;
  border: 3px solid var(--kvz-ink);
  border-radius: 50%;
  content: "";
  box-shadow: inset -4px -5px 0 rgba(112, 67, 30, 0.15);
}

.kvz-game-menu-art::before {
  top: -15px;
  left: 9%;
  background: var(--kvz-yellow);
}

.kvz-game-menu-art::after {
  right: 8%;
  bottom: -17px;
  background: var(--kvz-pink);
}

.kvz-game-menu-art img {
  width: 100%;
  max-height: min(62vh, 580px);
  aspect-ratio: 1.05;
  border-radius: 14px;
  object-fit: cover;
  object-position: center;
}

.kvz-game-menu-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  width: min(100%, 600px);
}

.kvz-game-menu-actions .kvz-game-button:first-child,
.kvz-game-menu-actions .kvz-game-button:last-child {
  grid-column: 1 / -1;
}

.kvz-game-panel {
  position: relative;
  padding: clamp(18px, 3vw, 34px);
  border: 5px solid var(--kvz-ink);
  border-radius: var(--kvz-radius);
  background:
    radial-gradient(circle at 7% 12%, rgba(255, 130, 173, 0.2) 0 36px, transparent 37px),
    radial-gradient(circle at 96% 88%, rgba(255, 225, 93, 0.3) 0 52px, transparent 53px),
    linear-gradient(180deg, #fff8d7, #f4d991);
  box-shadow: 0 8px 0 var(--kvz-bark), 0 18px 34px var(--kvz-shadow);
}

.kvz-game-panel::after {
  position: absolute;
  inset: 9px;
  border: 2px dashed rgba(112, 67, 30, 0.32);
  border-radius: 7px;
  content: "";
  pointer-events: none;
}

.kvz-game-title,
.kvz-game-subtitle {
  position: relative;
  z-index: 1;
  margin: 0;
  font-family: "Luckiest Guy", "Baloo 2", sans-serif;
  line-height: 0.98;
}

.kvz-game-title {
  color: var(--kvz-yellow);
  font-size: clamp(2.5rem, 6vw, 5.4rem);
  -webkit-text-stroke: 3px var(--kvz-ink);
  paint-order: stroke fill;
  text-shadow: 0 6px 0 var(--kvz-bark), 0 10px 20px rgba(37, 23, 15, 0.3);
}

.kvz-game-subtitle {
  color: var(--kvz-grass-deep);
  font-size: clamp(1.15rem, 2.2vw, 1.7rem);
  text-shadow: 2px 2px 0 rgba(255, 255, 255, 0.72);
}

.kvz-game-button {
  position: relative;
  z-index: 1;
  display: inline-flex;
  min-height: 50px;
  padding: 9px 18px;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 4px solid var(--kvz-ink);
  border-radius: 11px;
  color: var(--kvz-ink);
  background: linear-gradient(180deg, var(--kvz-paper), #edd99d);
  box-shadow: 0 5px 0 var(--kvz-bark), 0 9px 15px rgba(37, 23, 15, 0.18);
  font-weight: 900;
  line-height: 1.05;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  transition: transform 150ms var(--kvz-ease), box-shadow 150ms var(--kvz-ease), filter 150ms ease;
}

.kvz-game-button.primary,
.kvz-game-button.kvz-game-primary {
  background: linear-gradient(180deg, #fff67a, #f5b83e);
}

.kvz-game-button.secondary,
.kvz-game-button.kvz-game-secondary {
  background: linear-gradient(180deg, #efffd7, #8be25e);
}

.kvz-game-button.danger,
.kvz-game-button.kvz-game-danger {
  color: #fffdf5;
  background: linear-gradient(180deg, #ff8c79, var(--kvz-danger));
  text-shadow: 1px 2px 0 rgba(68, 40, 23, 0.35);
}

.kvz-game-button.back,
.kvz-game-button.kvz-game-back {
  background: linear-gradient(180deg, #ffd5e5, var(--kvz-pink));
}

.kvz-game-button:hover:not(:disabled) {
  filter: brightness(1.07) saturate(1.05);
  transform: translateY(-3px) rotate(-0.3deg);
  box-shadow: 0 8px 0 var(--kvz-bark), 0 13px 20px rgba(37, 23, 15, 0.2);
}

.kvz-game-button:active:not(:disabled) {
  transform: translateY(2px);
  box-shadow: 0 1px 0 var(--kvz-bark);
}

.kvz-game-button:disabled,
.kvz-game-button[aria-disabled="true"] {
  filter: grayscale(0.78) opacity(0.72);
  cursor: not-allowed;
}

.kvz-game-menu-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  padding: clamp(18px, 3vw, 32px);
}

.kvz-game-loading {
  display: grid;
  min-height: 100%;
  padding: 24px;
  place-items: center;
  text-align: center;
  background:
    radial-gradient(circle at 50% 40%, rgba(255, 225, 93, 0.62), transparent 18rem),
    linear-gradient(155deg, #a3e66e, #4aad3d);
}

.kvz-game-loading .kvz-game-panel {
  display: grid;
  width: min(560px, 100%);
  gap: 18px;
  justify-items: center;
}

.kvz-game-loading-track {
  position: relative;
  z-index: 2;
  width: min(420px, 100%);
  height: 28px;
  overflow: hidden;
  border: 4px solid var(--kvz-ink);
  border-radius: 999px;
  background: #d8bd7b;
  box-shadow: inset 0 4px 0 rgba(112, 67, 30, 0.18), 0 4px 0 var(--kvz-bark);
}

.kvz-game-loading-track > span,
.kvz-game-loading-track:empty::before {
  display: block;
  width: var(--progress, 0%);
  height: 100%;
  content: "";
  border-radius: inherit;
  background:
    repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.28) 0 9px, transparent 9px 18px),
    linear-gradient(90deg, var(--kvz-lime), var(--kvz-yellow));
  transition: width 220ms var(--kvz-ease);
}

.kvz-game-codex-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: clamp(12px, 2vw, 22px);
  padding: clamp(16px, 3vw, 30px);
}

.kvz-game-codex-card {
  position: relative;
  display: grid;
  min-width: 0;
  gap: 10px;
  align-content: start;
  overflow: hidden;
  padding: 12px;
  border: 4px solid var(--kvz-ink);
  border-radius: 14px;
  background: linear-gradient(180deg, #fffbe3, #eed593);
  box-shadow: 0 6px 0 var(--kvz-bark), 0 12px 22px var(--kvz-shadow);
  transition: transform 180ms var(--kvz-ease), box-shadow 180ms var(--kvz-ease);
}

.kvz-game-codex-card:hover {
  transform: translateY(-5px) rotate(-0.5deg);
  box-shadow: 0 10px 0 var(--kvz-bark), 0 18px 26px var(--kvz-shadow);
}

.kvz-game-codex-card h3,
.kvz-game-codex-card p {
  margin: 0;
}

.kvz-game-codex-card h3 {
  color: var(--kvz-grass-deep);
  font-size: 1.18rem;
  line-height: 1;
}

.kvz-game-codex-card p {
  font-size: 0.88rem;
  font-weight: 700;
  line-height: 1.25;
}

.kvz-game-codex-image {
  position: relative;
  width: 100%;
  aspect-ratio: 1.12;
  overflow: hidden;
  border: 3px solid var(--kvz-ink);
  border-radius: 10px;
  background:
    radial-gradient(circle at 50% 82%, rgba(37, 23, 15, 0.13) 0 22%, transparent 23%),
    linear-gradient(155deg, #e9ffd2, #81d85a);
}

.kvz-game-codex-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 7px 5px rgba(37, 23, 15, 0.22));
  transition: transform 240ms var(--kvz-ease);
}

.kvz-game-codex-card:hover .kvz-game-codex-image img {
  transform: translateY(-3px) scale(1.035);
}

.kvz-game-codex-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.kvz-game-stat-pill {
  display: inline-flex;
  min-height: 27px;
  padding: 3px 8px;
  align-items: center;
  gap: 4px;
  border: 2px solid var(--kvz-ink);
  border-radius: 999px;
  background: var(--kvz-mint);
  box-shadow: 0 2px 0 rgba(112, 67, 30, 0.45);
  font-size: 0.75rem;
  font-weight: 900;
  line-height: 1;
}

.kvz-game-stat-pill:nth-child(3n + 2) {
  background: #fff0a0;
}

.kvz-game-stat-pill:nth-child(3n) {
  background: #ffd5e5;
}

.kvz-game-locked {
  filter: grayscale(0.9) saturate(0.4);
}

.kvz-game-locked::after {
  position: absolute;
  inset: 0;
  z-index: 5;
  display: grid;
  padding: 18px;
  place-items: center;
  content: attr(data-locked-label);
  color: var(--kvz-paper);
  background: rgba(37, 23, 15, 0.7);
  font-size: 1rem;
  font-weight: 900;
  text-align: center;
  text-shadow: 1px 2px 0 var(--kvz-ink);
}

.kvz-game-settings-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
  max-width: 880px;
  padding: clamp(18px, 4vw, 42px);
  margin: 0 auto;
}

.kvz-game-range-row,
.kvz-game-toggle-row {
  position: relative;
  z-index: 1;
  display: grid;
  min-height: 64px;
  padding: 10px 12px;
  align-items: center;
  gap: 10px;
  border: 3px solid var(--kvz-ink);
  border-radius: 10px;
  background: rgba(255, 253, 245, 0.76);
  box-shadow: 0 4px 0 rgba(112, 67, 30, 0.5);
  font-weight: 900;
}

.kvz-game-range-row {
  grid-template-columns: minmax(110px, auto) minmax(100px, 1fr) auto;
}

.kvz-game-range-row input[type="range"] {
  width: 100%;
  accent-color: var(--kvz-grass-deep);
  cursor: pointer;
}

.kvz-game-toggle-row {
  grid-template-columns: 1fr auto;
  cursor: pointer;
}

.kvz-game-toggle-row input {
  width: 48px;
  height: 27px;
  margin: 0;
  appearance: none;
  border: 3px solid var(--kvz-ink);
  border-radius: 999px;
  background: #c4b897;
  box-shadow: inset 0 3px 0 rgba(37, 23, 15, 0.16);
  cursor: pointer;
  transition: background 150ms ease;
}

.kvz-game-toggle-row input::before {
  display: block;
  width: 17px;
  height: 17px;
  margin: 2px;
  border: 2px solid var(--kvz-ink);
  border-radius: 50%;
  content: "";
  background: var(--kvz-paper);
  box-shadow: 0 2px 0 rgba(112, 67, 30, 0.4);
  transition: transform 150ms var(--kvz-ease);
}

.kvz-game-toggle-row input:checked {
  background: var(--kvz-lime);
}

.kvz-game-toggle-row input:checked::before {
  transform: translateX(21px);
}

.kvz-game-gameplay {
  display: flex;
  height: 100%;
  min-height: 0;
  flex-direction: column;
  overflow: hidden;
  background: linear-gradient(180deg, #a7e9ef 0 25%, #72c953 25% 100%);
  user-select: none;
  -webkit-user-select: none;
  touch-action: none;
}

.kvz-game-hud {
  position: relative;
  z-index: 30;
  display: grid;
  grid-template-columns: minmax(175px, 0.8fr) minmax(220px, 1.6fr) minmax(150px, 0.7fr);
  gap: 10px;
  align-items: center;
  min-height: 76px;
  padding: 7px 10px 9px;
  border-bottom: 4px solid var(--kvz-ink);
  background:
    radial-gradient(circle at 4% 20%, rgba(255, 130, 173, 0.34) 0 14px, transparent 15px),
    linear-gradient(180deg, #fff8d9, #e7c77f);
  box-shadow: 0 5px 0 rgba(112, 67, 30, 0.48);
}

.kvz-game-hud-status {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 8px;
}

.kvz-game-energy-meter {
  position: relative;
  display: inline-flex;
  min-width: 118px;
  min-height: 48px;
  padding: 5px 11px 5px 48px;
  align-items: center;
  justify-content: center;
  border: 3px solid var(--kvz-ink);
  border-radius: 999px 12px 12px 999px;
  background: linear-gradient(180deg, #fff793, var(--kvz-yellow));
  box-shadow: 0 4px 0 var(--kvz-bark), inset 0 -3px 0 rgba(112, 67, 30, 0.12);
  font-family: "Luckiest Guy", "Baloo 2", sans-serif;
  font-size: 1.25rem;
  line-height: 1;
}

.kvz-game-energy-meter::before {
  position: absolute;
  top: 50%;
  left: 5px;
  width: 34px;
  height: 34px;
  border: 3px solid var(--kvz-ink);
  border-radius: 50%;
  content: "";
  background:
    radial-gradient(circle at 33% 33%, #fff 0 9%, transparent 10%),
    radial-gradient(circle at 50% 60%, var(--kvz-orange) 0 27%, transparent 28%),
    var(--kvz-yellow);
  box-shadow: 0 2px 0 var(--kvz-bark);
  transform: translateY(-50%);
}

.kvz-game-wave-meter {
  display: grid;
  min-width: 0;
  gap: 4px;
